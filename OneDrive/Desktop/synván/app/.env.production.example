# =============================================================================
# Simprão Production Environment Configuration
# =============================================================================
# This file contains all environment variables required for production deployment.
# Copy this file to .env.production and fill in the actual values.
#
# IMPORTANT SECURITY NOTES:
# - Generate all secrets using strong random generators (see comments below)
# - Never commit .env.production to version control
# - Use different values for JWT_SECRET, CSRF_SECRET, and NEXTAUTH_SECRET
# - Rotate secrets regularly (recommended: every 90 days)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.simprao.com.br
NEXT_PUBLIC_BASE_URL=https://simprao.com.br
PORT=3000

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Connection pool settings recommended for production:
# - pool_size: Number of connections (recommendation: 10-20 for medium traffic)
# - pool_timeout: Seconds to wait for available connection
# - statement_timeout: Kill slow queries (recommended: 30s)
DATABASE_URL="postgresql://simprao_user:CHANGE_ME@production-db.example.com:5432/simprao_prod?connection_limit=20&pool_timeout=30&statement_timeout=30000"

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate with: openssl rand -base64 32
# Minimum 32 characters for production security
JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32
JWT_EXPIRES_IN=24h

# IMPORTANT: Generate with: openssl rand -base64 32
# Used for NextAuth.js session encryption
NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32
NEXTAUTH_URL=https://simprao.com.br

# -----------------------------------------------------------------------------
# Cache Configuration (Redis)
# -----------------------------------------------------------------------------
# Format: redis://[:password@]host:port/db
# Recommended: Use Redis Sentinel or Cluster for high availability
REDIS_URL=redis://:CHANGE_ME_PASSWORD@production-redis.example.com:6379/0
REDIS_TLS_ENABLED=true

# -----------------------------------------------------------------------------
# Payment Gateway Configuration
# -----------------------------------------------------------------------------
# Supported providers: mercadopago, pagseguro, stone, rede
PAYMENT_GATEWAY_PROVIDER=mercadopago

# IMPORTANT: Obtain from payment gateway provider dashboard
# Production keys are different from sandbox keys
PAYMENT_GATEWAY_API_KEY=YOUR_PRODUCTION_API_KEY_FROM_GATEWAY
PAYMENT_GATEWAY_SECRET=YOUR_PRODUCTION_SECRET_FROM_GATEWAY
PAYMENT_GATEWAY_SANDBOX=false

# -----------------------------------------------------------------------------
# Email Service Configuration
# -----------------------------------------------------------------------------
# Supported providers: sendgrid, ses, mailgun, smtp
EMAIL_PROVIDER=sendgrid

# SendGrid (Recommended for production)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM=noreply@simprao.com.br
SENDGRID_FROM_NAME=Simprão

# AWS SES Alternative (if EMAIL_PROVIDER=ses)
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# SMTP Alternative (if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=YOUR_SMTP_USER
# SMTP_PASSWORD=YOUR_SMTP_PASSWORD
# SMTP_SECURE=true

# -----------------------------------------------------------------------------
# SMS Service Configuration
# -----------------------------------------------------------------------------
# Supported providers: twilio, vonage
SMS_PROVIDER=twilio

# Twilio Configuration
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+5511999999999

# Vonage Alternative (if SMS_PROVIDER=vonage)
# VONAGE_API_KEY=YOUR_VONAGE_API_KEY
# VONAGE_API_SECRET=YOUR_VONAGE_API_SECRET
# VONAGE_PHONE_NUMBER=5511999999999

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate with: openssl rand -base64 32
# CSRF protection for form submissions
CSRF_ENABLED=true
CSRF_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Content Security Policy for production
CSP_ENABLED=true
CSP_REPORT_URI=https://csp-report-uri.example.com

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking
# -----------------------------------------------------------------------------
# Sentry for error tracking (recommended for production)
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Fee Structure Configuration
# -----------------------------------------------------------------------------
# Revenue threshold (in cents) for Bileto fee tier calculation
# 10000 = R$100.00 (events earning above this pay 10%, otherwise 15%)
BILETO_FEE_TIER_THRESHOLD=10000

# -----------------------------------------------------------------------------
# Half-Price Policy Configuration
# -----------------------------------------------------------------------------
# Federal Law 12.933/2013 compliance
# When true: Elderly (60+) have unlimited half-price tickets
# When false: Elderly are subject to 40% cap like other groups
ELDERLY_HALF_PRICE_UNLIMITED=true

# -----------------------------------------------------------------------------
# Lot Transition Configuration
# -----------------------------------------------------------------------------
# Behavior for unsold tickets when lots expire
# expire: Unsold tickets remain unavailable (recommended for most events)
# rollover: Unsold tickets roll over to next active lot
LOT_UNSOLD_BEHAVIOR=expire

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
# Requests per minute per IP address
RATE_LIMIT_AUTH_REGISTER=5
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_ORDERS_CREATE=20
RATE_LIMIT_PAYMENTS_PROCESS=10
RATE_LIMIT_GLOBAL=100

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log levels: error, warn, info, debug
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REQUEST_ID=true
LOG_USER_ID=true

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
# Database backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# State-Specific Tax Configuration
# -----------------------------------------------------------------------------
# State-specific tax rates (as decimal, e.g., 0.17 for 17%)
# Only needed for ES (17%), RR (17%), AC (16%)
# Other states use standard federal rates
STATE_TAX_ES_ENABLED=true
STATE_TAX_RR_ENABLED=true
STATE_TAX_AC_ENABLED=true

# -----------------------------------------------------------------------------
# Third-Party Integrations (Optional)
# -----------------------------------------------------------------------------
# Zoom for streaming events (P2 feature)
# ZOOM_API_KEY=YOUR_ZOOM_API_KEY
# ZOOM_API_SECRET=YOUR_ZOOM_API_SECRET
# ZOOM_WEBHOOK_SECRET=YOUR_ZOOM_WEBHOOK_SECRET

# -----------------------------------------------------------------------------
# Webhook Configuration
# -----------------------------------------------------------------------------
# Payment gateway webhook endpoint secrets
# Used to verify incoming webhook notifications
WEBHOOK_SECRET_PAYMENT_GATEWAY=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# -----------------------------------------------------------------------------
# CDN & Static Assets (Optional)
# -----------------------------------------------------------------------------
# AWS CloudFront or similar CDN
# CDN_DOMAIN=https://cdn.simprao.com.br

# AWS S3 for file uploads
# AWS_S3_BUCKET=simprao-uploads
# AWS_S3_REGION=sa-east-1
# AWS_S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
# AWS_S3_SECRET_KEY=YOUR_S3_SECRET_KEY

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to production:
#
# [ ] Generate unique secrets for JWT_SECRET, CSRF_SECRET, NEXTAUTH_SECRET
#     Use: openssl rand -base64 32
#
# [ ] Update DATABASE_URL with production database credentials
#     Include connection pooling: ?connection_limit=20
#
# [ ] Configure REDIS_URL with production Redis instance
#     Enable TLS for secure connections
#
# [ ] Obtain production API keys from payment gateway provider
#     Set PAYMENT_GATEWAY_SANDBOX=false
#
# [ ] Configure email provider with production credentials
#     Test email delivery before going live
#
# [ ] Set up Sentry or similar error tracking
#     Verify error reports are received
#
# [ ] Review and adjust rate limits based on expected traffic
#
# [ ] Configure backup schedule for database
#     Test restore procedure
#
# [ ] Enable all security headers and CSP
#
# [ ] Set up monitoring dashboards (Grafana, DataDog, etc.)
#
# [ ] Configure SSL/TLS certificates (Let's Encrypt or commercial)
#
# [ ] Review fee structure and tax configuration for accuracy
#
# =============================================================================
