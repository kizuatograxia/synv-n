DATABASE_URL=postgresql://sympla:password@localhost:5432/sympla
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Logging Configuration
# Options: debug, info, warn, error
# - debug: All logs (development only)
# - info: General informational messages
# - warn: Warnings and errors (production default)
# - error: Errors only
LOG_LEVEL=info

JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# Email Provider: sendgrid, ses, mailgun, or smtp
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@sympla.com

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Mailgun Configuration (if EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# SMS Provider: twilio, vonage
SMS_PROVIDER=twilio

# Twilio Configuration (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Vonage Configuration (if SMS_PROVIDER=vonage)
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_PHONE_NUMBER=15551234567

PAYMENT_GATEWAY_PROVIDER=mercadopago
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-api-key
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret
PAYMENT_GATEWAY_SANDBOX=true

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# CSRF Protection Configuration
CSRF_ENABLED=true
CSRF_SECRET=change-me-in-production-use-openssl-rand-base64-32

# Fee Structure Configuration
BILETO_FEE_TIER_THRESHOLD=10000

# Half-Price Policy Configuration
# When true, elderly (60+) have no limit on half-price tickets
# When false, elderly are subject to the 40% cap like other groups
ELDERLY_HALF_PRICE_UNLIMITED=true

# Lot Transition Configuration
# expire: Unsold tickets from expired lots remain unavailable
# rollover: Unsold tickets from expired lots roll over to the next active lot
LOT_UNSOLD_BEHAVIOR=expire
